[Unit]
Description=SQL Conv AI Bedrock WebService (Docker Compose)
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/ec2-user/ai/async-conv
ExecStart=/usr/bin/docker-compose up
ExecStop=/usr/bin/docker-compose down
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target